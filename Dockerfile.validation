FROM python:3.12-slim

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    ANSIBLE_LOCAL_TEMP=/workspace/.ansible/localtmp \
    ANSIBLE_REMOTE_TEMP=/workspace/.ansible/tmp \
    ANSIBLE_COLLECTIONS_PATH=/opt/ansible/collections

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends make ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip \
    && python -m pip install ansible-core PyYAML requests \
    && mkdir -p /opt/ansible/collections \
    && ansible-galaxy collection install f5networks.f5os -p /opt/ansible/collections

CMD ["make", "validate"]
